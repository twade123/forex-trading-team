# ────────────────────────────────────────────────────────────────
# Forex Trading Team — example environment configuration
# Copy this file to .env and fill in real values. Never commit .env.
# ────────────────────────────────────────────────────────────────

# ── Broker (OANDA) ──────────────────────────────────────────────
OANDA_API_KEY=your-oanda-api-token-here
OANDA_ACCOUNT_ID=000-000-0000000-000
OANDA_ENVIRONMENT=demo          # "demo" or "live"

# Optional: read the OANDA token from a file instead of an env var
# OANDA_API_KEY_PATH=~/secrets/oanda_token.txt

# ── Anthropic (optional fallback for validator) ─────────────────
# The production validator runs on a local Qwen3.5 35B (MLX). Set this only if
# you want to A/B against Anthropic, run the ghost validator, or use Anthropic
# as a fallback when the local server is down.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Local MLX serving (Qwen 35B LoRA adapter) ───────────────────
# Path to the LoRA adapter directory used by Source/serving/vmlx_*.py
# Adapter weights are not included in this repo.
VMLX_ADAPTER_PATH=/path/to/your/35b_mlx_adapter

# ── User / multi-tenant ─────────────────────────────────────────
# Identifies which user owns the trading workspace. Used for routing
# trades to the right OANDA account in multi-tenant deployments.
TRADING_USER_ID=1

# ── System mode flags ───────────────────────────────────────────
JARVIS_TRADING_MODE=1            # enables trading-team execution paths
# KRONOS_SKIP_SCOUT_BIAS=1       # disables experimental kronos signal bias

# ── Optional integrations ───────────────────────────────────────
# WOLFRAM_API_KEY=your-wolfram-app-id   # used by economic-data agents

# ── Output paths ────────────────────────────────────────────────
# CHART_OUTPUT_DIR=/tmp/forex_charts   # where chart_generator writes PNGs
